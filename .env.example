DATABASE_URL=sqlite:///./data/market.db
APP_HOST=127.0.0.1
APP_PORT=8000
APP_ENV=dev
LOG_LEVEL=INFO

DSE_BASE_URL=https://www.dsebd.org
CSE_BASE_URL=https://www.cse.com.bd
HTTP_TIMEOUT_SECONDS=20
HTTP_USER_AGENT=DSE-AI-Trader-OS/0.1 (data-foundation)

COLLECT_INTRADAY_CRON_MINUTE=*/2
COLLECT_EOD_CRON_HOUR=16
COLLECT_EOD_CRON_MINUTE=30
QUALITY_CHECK_CRON_MINUTE=*/15

# DSE/CSE official trading hours (Asia/Dhaka), used to gate scheduled collection.
MARKET_TZ=Asia/Dhaka
MARKET_OPEN_HOUR=10
MARKET_OPEN_MINUTE=0
MARKET_CLOSE_HOUR=14
MARKET_CLOSE_MINUTE=30
